# Copy to .env, fill in values, then `chmod 600 .env`. Never commit .env.

# JPO 特許情報取得API credentials (OAuth2 Resource Owner Password Grant)
# Apply via PA0630@jpo.go.jp — see CLAUDE.md for details.
JPO_USERNAME=
JPO_PASSWORD=

# Optional: pre-issued bearer token (skips /auth/token call)
# JPO_TOKEN=

# JPO API endpoints — defaults usually fine
JPO_API_BASE=https://ip-data.jpo.go.jp
JPO_AUTH_TOKEN_URL=https://ip-data.jpo.go.jp/auth/token

# Feature switches
JPO_ENABLE_OPD=1                       # 0 to hide all OPD tools (no contract / quota exhausted)
EXTERNAL_GOOGLE_PATENTS_ENABLED=1      # 0 to hide tools_external/* entirely

# Server
MCP_HOST=0.0.0.0
MCP_PORT=8765
LOG_LEVEL=INFO

# JSONL access log (every JPO + external call writes one line here)
# Used by scripts/summarize_logs.py for daily quota reporting.
# ACCESS_LOG_PATH=/app/logs/access.jsonl

# OAuth 2.1 (optional — leave both empty to disable auth, e.g. for LAN-only use)
# When ISSUER_URL + MASTER_PASSWORD are both set, the server requires OAuth.
# Tokens & registered clients persist to MCP_OAUTH_DB_PATH (SQLite).
# MCP_OAUTH_ISSUER_URL=https://ipmcp.example.com
# MCP_OAUTH_MASTER_PASSWORD=
# MCP_OAUTH_DB_PATH=/app/data/oauth.db    # default; override only if mounting elsewhere
